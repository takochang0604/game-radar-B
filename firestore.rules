rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // 頁面瀏覽計數器：counters/{toolId}
    // ============================================================
    match /counters/{toolId} {
      allow read, write: if true;
    }

    // ============================================================
    // 訂閱分帳工具：users/{userId}/subscriptions/...
    // ============================================================
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================================
    // 備忘錄 App：artifacts/{appId}/public/data/...
    // ============================================================
    match /artifacts/{appId}/public/data/{document=**} {

      // ── room_profile：含 pwHash，禁止前端讀寫 ──────────────────
      // 只有 Cloud Functions (Admin SDK) 才能存取
      match /{roomId}/room_profile {
        allow read, write: if false;
      }

      // ── account_registries：帳號登錄檔 ───────────────────────
      // 只允許讀（確認帳號是否存在由後端做），不允許前端直接寫
      match /account_registries/{accountId} {
        allow read: if false;
        allow write: if false;
      }

      // ── 訪客計數：任何人可讀，禁止任意寫 ────────────────────────
      match /app_stats/visitor_count {
        allow read: if true;
        // 只允許 increment（Cloud Functions 用 Admin 即可繞過這條規則）
        allow write: if true;
      }

      // ── 備忘錄資料（roomId 內的其他文件）────────────────────────
      // 允許所有人讀寫（資料已用 AES-256-GCM 加密，沒有密碼無法解密）
      // 如果往後要加更嚴格的規則可在此調整
      match /{roomId}/{memoId} {
        allow read, write: if true;
      }

      // ── 分類資料 ────────────────────────────────────────────
      match /{roomIdCats}/{catId} {
        allow read, write: if true;
      }
    }

    // ============================================================
    // 遊戲競爭力分析 — 追蹤清單（跨裝置同步，公開讀寫）
    // ============================================================
    match /gameTracking/{docId} {
      allow read, write: if true;
    }

    // ============================================================
    // 遊戲競爭力分析（公開讀取，僅 Admin SDK 可寫）
    // ============================================================
    match /gameAnalysis/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /gameAnalysis/{docId}/{sub=**} {
      allow read: if true;
      allow write: if false;
    }

    // ============================================================
    // 遊戲競爭力分析 — 測試版（dev 分支用，同正式版權限）
    // ============================================================
    match /gameAnalysis-dev/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /gameAnalysis-dev/{docId}/{sub=**} {
      allow read: if true;
      allow write: if false;
    }

  }
}
